    {
        "id": "32ecabb8ba17a03b",
        "type": "function",
        "z": "fa93e58910751fef",
        "name": "function 1",
        "func": "let payload = JSON.parse(msg.payload.toString());\nmsg.topic = \"campus/b01/f01/\" + payload.room_id + \"/telemetry\";\nmsg.payload = {\n    timestamp: Math.floor(Date.now() / 1000),\n    sensors: payload.sensors,\n    actuators: payload.actuators\n};\n\nreturn msg;",
