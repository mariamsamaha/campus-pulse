    {
        "id": "efea8aa241951352",
        "type": "function",
        "z": "fa93e58910751fef",
        "name": "function 2",
        "func": "let messages = msg.payload; \nlet totalTemp = 0;\nlet totalHum = 0;\nlet roomCount = messages.length;\n\nmessages.forEach(function(m) {\n    // Navigate the project's standard JSON structure\n    totalTemp += m.payload.sensors.temperature;\n    totalHum += m.payload.sensors.humidity;\n});\n\n// Calculate averages\nlet avgTemp = (totalTemp / roomCount).toFixed(2);\nlet avgHum = (totalHum / roomCount).toFixed(2);\n\nmsg.topic = \"campus/b01/f01/status\";\nmsg.payload = {\n    floor: \"01\",\n    timestamp: Math.floor(Date.now() / 1000),\n    avg_temperature: parseFloat(avgTemp),\n    avg_humidity: parseFloat(avgHum),\n    reporting_nodes: roomCount,\n    status: (roomCount >= 20) ? \"Healthy\" : \"Degraded\" // Fleet Health check [cite: 39, 48-50]\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 900,
        "y": 400,
        "wires": [
            [
                "80ac76ff41e873bb"
            ]
        ]
    },
    {
        "id": "cffca26b6b58c7e3",
        "type": "function",
        "z": "fa93e58910751fef",
        "name": "function 3",
        "func": "let parts = msg.topic.split('/');\nlet floor = parseInt(parts[2].replace('f', '')); // Result: 1\nlet roomIDStr = parts[3]; // Result: \"r113\"\nlet roomNum = parseInt(roomIDStr.replace('r', '')); // Result: 113\n\nlet room_offset = roomNum - 11; \nlet dynamicPort = 5683 + (floor - 1) * 10 + room_offset;\n\nmsg.method = \"PUT\";\nmsg.confirmable = true;\nmsg.url = \"coap://127.0.0.1:\" + dynamicPort + \"/\" + parts[2] + \"/\" + roomIDStr + \"/actuators/hvac\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
